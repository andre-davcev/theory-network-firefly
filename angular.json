    "firefly-web": {
      "projectType": "application",
      "root": "apps/firefly/web",
      "sourceRoot": "apps/firefly/web/src",
      "prefix": "theory",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/apps/firefly/web",
            "index": "apps/firefly/web/src/index.html",
            "main": "apps/firefly/web/src/main.ts",
            "polyfills": "apps/firefly/web/src/polyfills.ts",
            "tsConfig": "apps/firefly/web/tsconfig.app.json",
            "aot": true,
            "assets": [
              "apps/firefly/web/src/favicon.ico",
              "apps/firefly/web/src/assets"
            ],
            "styles": ["apps/firefly/web/src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/firefly/web/src/environments/environment.ts",
                  "with": "apps/firefly/web/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "firefly-web:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "firefly-web:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "firefly-web:build"
          }
        },
        "lint": {
          "builder": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": [
              "apps/firefly/web/src/**/*.ts",
              "apps/firefly/web/src/**/*.html"
            ]
          }
        },
        "test": {
          "builder": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/firefly/web"],
          "options": {
            "jestConfig": "apps/firefly/web/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "firefly-web-e2e": {
      "root": "e2e/firefly-web",
      "sourceRoot": "e2e/firefly-web/src",
      "projectType": "application",
      "architect": {
        "e2e": {
