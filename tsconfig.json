{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "dist/apps/firefly/functions",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es5",
    "noUnusedLocals": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2017",
      "dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@theory/*": [
        "libs/*"
      ],
      "@theory/ionic": [
        "xplat/ionic/index.ts"
      ],
      "@theory/ionic/*": [
        "xplat/ionic/*"
      ],
      "@theory/nativescript": [
        "xplat/nativescript/index.ts"
      ],
      "@theory/nativescript/*": [
        "xplat/nativescript/*"
      ],
      "@theory/web": [
        "xplat/web/index.ts"
      ],
      "@theory/web/*": [
        "xplat/web/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
