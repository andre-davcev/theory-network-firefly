{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "dist/apps/firefly/functions",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es5",
    "noUnusedLocals": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2017",
      "dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@theory/scss": [
        "libs/scss"
      ],
      "@theory/capacitor": [
        "libs/capacitor/src/index.ts"
      ],
      "@theory/core": [
        "libs/core/src/index.ts"
      ],
      "@theory/device": [
        "libs/device/src/index.ts"
      ],
      "@theory/firebase": [
        "libs/firebase/src/index.ts"
      ],
      "@theory/foursquare": [
        "libs/foursquare/src/index.ts"
      ],
      "@theory/ionic": [
        "libs/ionic/src/index.ts"
      ],
      "@theory/nativescript": [
        "libs/nativescript/src/index.ts"
      ],
      "@theory/web": [
        "libs/web/src/index.ts"
      ],
      "@firefly/core": [
        "libs/firefly/core/src/index.ts"
      ],
      "@firefly/mobile": [
        "libs/firefly/mobile/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
