{
  "compileOnSave": false,
  "compilerOptions": {
    "importHelpers": true,
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es5",
    "noUnusedLocals": true,
    "allowSyntheticDefaultImports": true,
    "typeRoots": ["node_modules/@types"],
    "lib": ["es2017", "dom"],
    "baseUrl": ".",
    "paths": {
      "@firefly/cloud": ["apps/firefly-functions/src/shared/index.ts"],
      "@firefly/mobile": ["libs/firefly-mobile/src/index.ts"],
      "@firefly/shared": ["libs/firefly-shared/src/index.ts"],
      "@firefly/web": ["libs/firefly-web/src/index.ts"],
      "@theory/bigdatacloud": ["libs/bigdatacloud/src/index.ts"],
      "@theory/capacitor": ["libs/capacitor/src/index.ts"],
      "@theory/core": ["libs/core/src/index.ts"],
      "@theory/firebase": ["libs/firebase/src/index.ts"],
      "@theory/google": ["libs/google/src/index.ts"],
      "@theory/ionic": ["libs/ionic/src/index.ts"],
      "@theory/mapbox": ["libs/mapbox/src/index.ts"],
      "@theory/ngxs": ["libs/ngxs/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
