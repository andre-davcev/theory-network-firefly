{
    "compilerOptions" :
    {
        "baseUrl"                      : ".",
        "allowSyntheticDefaultImports" : true,
        "declaration"                  : false,
        "emitDecoratorMetadata"        : true,
        "experimentalDecorators"       : true,
        "module"                       : "es2015",
        "moduleResolution"             : "node",
        "sourceMap"                    : true,
        "target"                       : "es5",

        "lib" :
        [
            "dom",
            "es2017"
        ],

        "paths" :
        {
            "*" : ["modules/*"]
        },

        "typeRoots" :
        [
            "node_modules/@types"
        ],

        "types" :
        [
            "node",
            "jasmine"
        ]
    },

    "include" :
    [
        "src/**/*.ts"
    ],

    "exclude" :
    [
        "node_modules"
    ],
    
    "compileOnSave" : false,

    "atom":
    {
        "rewriteTsconfig" : false
    }
}