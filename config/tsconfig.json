        "module"                 : "commonjs",
        "emitDecoratorMetadata"  : true,
        "experimentalDecorators" : true,
        "sourceMap"              : true,
        "declaration"            : true
    },

    "include" :
    [
        "build/modules/theory-network/*.ts"
    ],

