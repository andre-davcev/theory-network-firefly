  "scripts": {
    "fire-ionic-build": "npm run build.ionic.firefly",
    "fire-ionic-watch": "cd apps/firefly/mobile && ng build --watch",
    "fire-ionic-sync": "npm run sync.ionic.firefly",
    "fire-ionic-update-ios": "npm run prepare.ionic.firefly.ios",
    "fire-ionic-update--android": "npm run prepare.ionic.firefly.android",
