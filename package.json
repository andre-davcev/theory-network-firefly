    "@ngxs/devtools-plugin": "^3.2.0",
    "@ngxs/router-plugin": "^3.2.0",
    "@ngxs/store": "^3.2.0",
    "@nrwl/nx": "6.4.0",
    "@theory/scss": "file:libs/scss",
    "cordova-plugin-firebase": "^2.0.5",
    "cordova-plugin-globalization": "^1.11.0",
    "cordova-plugin-ionic": "^5.1.2",
    "core-js": "^2.5.3",
    "firebase": "^5.5.4",
