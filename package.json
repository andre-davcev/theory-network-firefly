    "fire-functions-deploy-dev": "cd apps/firefly && firebase use dev && firebase deploy --only functions",
    "fire-functions-deploy-prod": "cd apps/firefly && firebase use prod && firebase deploy --only functions",
    "fire-design-icon": "grunt sketch_export:icon",
    "fire-design-splash": "grunt sketch_export:splash",
    "fire-design-logo": "grunt sketch_export:logo",
    "fire-design-text": "grunt sketch_export:text",
    "fire-design-exports": "grunt exports",
    "lib-build-all": "npm run lib-build-firefly-core && npm run lib-build-firefly-mobile && npm run lib-build-theory-capacitor && npm run lib-build-theory-core && npm run lib-build-theory-device && npm run lib-build-theory-firebase && npm run lib-build-theory-foursquare && npm run lib-build-theory-google && npm run lib-build-theory-ionic && npm run lib-build-theory-mapbox && npm run lib-build-theory-web",
    "lib-build-firefly-core": "ng build firefly-core",
    "lib-build-firefly-mobile": "ng build firefly-mobile",
    "lib-build-theory-capacitor": "ng build capacitor",
    "lib-build-theory-core": "ng build core",
    "lib-build-theory-device": "ng build device",
    "lib-build-theory-firebase": "ng build firebase",
    "lib-build-theory-foursquare": "ng build foursquare",
    "lib-build-theory-google": "ng build google",
    "lib-build-theory-ionic": "ng build ionic",
    "lib-build-theory-mapbox": "ng build mapbox",
    "lib-build-theory-web": "ng build web",
    "npm-clean-cache": "npm cache clean --force && rm -rf ~/.npm && rm -f package-lock.json && rm -rf node_modules",
    "npm-global-install-linux": "sudo npm install -g @angular/cli @nrwl/schematics ionic firebase-tools",
    "npm-global-install": "npm install -g @angular/cli @nrwl/schematics ionic firebase-tools",
    "capacitor-update": "npx cap update",
    "capacitor-add-ios": "npx cap add ios",
    "capacitor-add-android": "npx cap add android",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "./node_modules/.bin/nx lint && ng lint",
    "e2e": "ng e2e",
    "affected:apps": "./node_modules/.bin/nx affected:apps",
    "affected:libs": "./node_modules/.bin/nx affected:libs",
    "affected:build": "./node_modules/.bin/nx affected:build",
    "affected:e2e": "./node_modules/.bin/nx affected:e2e",
    "affected:test": "./node_modules/.bin/nx affected:test",
    "affected:lint": "./node_modules/.bin/nx affected:lint",
    "affected:dep-graph": "./node_modules/.bin/nx affected:dep-graph",
    "format": "./node_modules/.bin/nx format:write",
    "format:write": "./node_modules/.bin/nx format:write",
    "format:check": "./node_modules/.bin/nx format:check",
    "update": "ng update @nrwl/schematics",
    "update:check": "ng update",
    "workspace-schematic": "./node_modules/.bin/nx workspace-schematic",
    "dep-graph": "./node_modules/.bin/nx dep-graph",
    "help": "./node_modules/.bin/nx help",
    "clean": "npx rimraf -- hooks node_modules package-lock.json && npm i",
    "build.ionic.firefly": "cd apps/firefly/mobile && npm run build:web",
    "prepare.ionic.firefly": "npm run clean && npm run clean.ionic.firefly && npm run build.ionic.firefly",
    "prepare.ionic.firefly.ios": "npm run prepare.ionic.firefly && npm run clean.ionic.firefly.ios && cd apps/firefly/mobile && npm run cap.add.ios",
    "prepare.ionic.firefly.android": "npm run prepare.ionic.firefly && npm run clean.ionic.firefly.android && cd apps/firefly/mobile && npm run cap.add.android",
    "open.ionic.firefly.ios": "cd apps/firefly/mobile && npm run cap.ios",
    "open.ionic.firefly.android": "cd apps/firefly/mobile && npm run cap.android",
    "sync.ionic.firefly": "cd apps/firefly/mobile && npm run cap.copy",
    "start.ionic.firefly": "cd apps/firefly/mobile && npm start",
    "clean.ionic.firefly": "cd apps/firefly/mobile && npx rimraf -- hooks node_modules platforms www plugins package-lock.json && npm i && rimraf -- package-lock.json",
    "clean.ionic.firefly.ios": "cd apps/firefly/mobile && npx rimraf -- ios",
    "clean.ionic.firefly.android": "cd apps/firefly/mobile && npx rimraf -- android"
  },
