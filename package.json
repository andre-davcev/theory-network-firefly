{
  "name": "theory",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "fire-ionic-build-dev": "npm run build.ionic.firefly",
    "fire-ionic-build-prod": "npm run build.ionic.firefly.prod",
    "fire-ionic-ios-dev-config": "cp apps/firefly-mobile/config/ios/dev/GoogleService-Info.plist apps/firefly-mobile/ios/App && cp apps/firefly-mobile/config/ios/dev/App.entitlements apps/firefly-mobile/ios/App/App",
    "fire-ionic-ios-prd-config": "cp apps/firefly-mobile/config/ios/prd/GoogleService-Info.plist apps/firefly-mobile/ios/App && cp apps/firefly-mobile/config/ios/prd/App.entitlements apps/firefly-mobile/ios/App/App",
    "fire-ionic-ios-dev-build": "npm run fire-ionic-ios-dev-config && npm run build.ionic.firefly",
    "fire-ionic-ios-prd-build": "npm run fire-ionic-ios-prd-config &&  npm run build.ionic.firefly.prod",
    "fire-ionic-watch": "ng build firefly-mobile --watch",
    "fire-ionic-serve": "ionic serve firefly-mobile --watch",
    "fire-ionic-serve-ios": "ionic serve firefly-mobile --watch --platform ios",
    "fire-ionic-serve-android": "ionic serve firefly-mobile --watch android",
    "fire-ionic-serve-prod": "npm run fire-ionic-build-prod && cd apps/firefly-mobile/www && npx serve -p 8100",
    "fire-ionic-serve-lab": "ionic serve firefly-mobile --watch --lab",
    "fire-ionic-sync": "npm run sync.ionic.firefly",
    "fire-ionic-update-ios": "npm run prepare.ionic.firefly.ios",
    "fire-ionic-update-android": "npm run prepare.ionic.firefly.android",
    "fire-functions-build": "cd apps/firefly/cloud && tsc",
    "fire-rules-deploy": "cd apps/firefly/cloud && firebase deploy --only firestore:rules",
    "fire-functions-deploy-dev": "cd apps/firefly && firebase use dev && firebase deploy --only functions",
    "fire-functions-deploy-prod": "cd apps/firefly && firebase use prod && firebase deploy --only functions",
    "fire-design-icon": "grunt sketch_export:icon",
    "fire-design-splash": "grunt sketch_export:splash",
    "fire-design-logo": "grunt sketch_export:logo",
    "fire-design-text": "grunt sketch_export:text",
    "fire-design-exports": "grunt exports",
    "fire-resources": "cd apps/firefly-mobile && ionic cordova resources",
    "lib-build-all": "npm run lib-build-firefly-core && npm run lib-build-firefly-mobile && npm run lib-build-theory-capacitor && npm run lib-build-theory-core && npm run lib-build-theory-device && npm run lib-build-theory-firebase && npm run lib-build-theory-google && npm run lib-build-theory-ionic && npm run lib-build-theory-mapbox && npm run lib-build-theory-web",
    "lib-build-firefly-core": "ng build firefly-core",
    "lib-build-firefly-mobile": "ng build firefly-mobile",
    "lib-build-theory-capacitor": "ng build capacitor",
    "lib-build-theory-core": "ng build core",
    "lib-build-theory-firebase": "ng build firebase",
    "lib-build-theory-google": "ng build google",
    "lib-build-theory-ionic": "ng build ionic",
    "lib-build-theory-mapbox": "ng build mapbox",
    "lib-build-theory-web": "ng build web",
    "npm-clean-cache": "npm cache clean --force && rm -rf ~/.npm && rm -f package-lock.json && rm -rf node_modules",
    "npm-global-install-linux": "sudo npm install -g @angular/cli nx @ionic/cli firebase-tools grunt-cli",
    "npm-global-install": "npm install -g @angular/cli nx @ionic/cli firebase-tools grunt-cli",
    "nrwl-update": "nx migrate latest",
    "npm-outdated": "npm outdated",
    "capacitor-update": "npx cap update",
    "capacitor-add-ios": "npx cap add ios",
    "capacitor-add-android": "npx cap add android",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "./node_modules/.bin/nx workspace-lint && ng lint",
    "e2e": "ng e2e",
    "affected:apps": "./node_modules/.bin/nx affected:apps",
    "affected:libs": "./node_modules/.bin/nx affected:libs",
    "affected:build": "./node_modules/.bin/nx affected:build",
    "affected:e2e": "./node_modules/.bin/nx affected:e2e",
    "affected:test": "./node_modules/.bin/nx affected:test",
    "affected:lint": "./node_modules/.bin/nx affected:lint",
    "affected:dep-graph": "./node_modules/.bin/nx affected:dep-graph",
    "format": "./node_modules/.bin/nx format:write",
    "format:write": "./node_modules/.bin/nx format:write",
    "format:check": "./node_modules/.bin/nx format:check",
    "update": "nx migrate latest",
    "update:check": "ng update",
    "dep-graph": "./node_modules/.bin/nx dep-graph",
    "help": "./node_modules/.bin/nx help",
    "nx": "nx",
    "postinstall": "ngcc --properties es2015 browser module main && node ./decorate-angular-cli.js",
    "install-exact": "npm ci",
    "workspace-generator": "nx workspace-generator",
    "clean": "npx rimraf hooks node_modules package-lock.json && npm i --legacy-peer-deps",
    "clean.ionic.firefly": "cd apps/firefly-mobile && npx rimraf hooks node_modules platforms www plugins package-lock.json && npm i --legacy-peer-deps && npx rimraf -- package-lock.json",
    "build.ionic.firefly": "nx build firefly-mobile",
    "build.ionic.firefly.prod": "nx build firefly-mobile --prod",
    "prepare.ionic.firefly": "npm run clean && npm run clean.ionic.firefly && npm run build.ionic.firefly",
    "prepare.ionic.firefly.ios": "npm run prepare.ionic.firefly && cd apps/firefly-mobile && npx rimraf -- ios && npm run cap.add.ios",
    "prepare.ionic.firefly.android": "npm run prepare.ionic.firefly && cd apps/firefly-mobile && npx rimraf -- android && npm run cap.add.android",
    "open.ionic.firefly.ios": "cd apps/firefly-mobile && npm run cap.ios",
    "open.ionic.firefly.android": "cd apps/firefly-mobile && npm run cap.android",
    "sync.ionic.firefly": "cd apps/firefly-mobile && npm run cap.copy"
  },
  "private": true,
