service cloud.firestore {
  match /databases/{database}/documents {
		match /cities/{id} {
      allow get:    if false;
      allow list:   if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    match /debug/** {
      allow get:    if false;
      allow list:   if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
		match /events/{id} {
      allow get:    if isUser(uid());
      allow list:   if isAuthenticated(auth());
      allow create: if isUser(uid());
      allow update: if isUser(uid());
      allow delete: if isUser(uid());
    }
		match /interest-streams/{id} {
      allow get:    if isUser(uid());
      allow list:   if isAuthenticated(auth());
      allow create: if isUser(uid());
      allow update: if isUser(uid());
      allow delete: if isUser(uid());
    }
    match /interests/{id} {
      allow get:    if isUser(uid());
      allow list:   if isAuthenticated(auth());
      allow create: if isUser(uid());
      allow update: if isUser(uid());
      allow delete: if isUser(uid());
    }
    match /user-profiles/{id} {
      allow get:    if isUser(uid());
      allow list:   if isUser(uid());
      allow create: if isUser(uid());
      allow update: if isUser(uid());
      allow delete: if isUser(uid());
    }
    match /users/{id} {
      allow get:    if isUser(uid());
      allow list:   if isUser(uid());
      allow create: if isUser(uid());
      allow update: if isUser(uid());
      allow delete: if isUser(uid());
    }
    match /users/anonymous {
      allow get:    if false;
      allow list:   if false;
      allow create: if isAnonymous(auth());
      allow update: if isAnonymous(auth());
      allow delete: if false;
    }

    function auth()                             { return request.auth; }
    function uid()                              { return auth().uid; }
    function isUser(uid)               					{ return uid != null; }
    function isAuthenticated(auth)              { return isUser(auth.uid) || isAnonymous(auth); }
    function isAnonymous(auth)                  { return auth.token.firebase.sign_in_provider == 'anonymous'; }
  }
}
