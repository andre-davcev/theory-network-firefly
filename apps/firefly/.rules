service cloud.firestore {
  match /databases/{database}/documents {
    match /alerts/{alertId} {
      allow get:    alertCanGet(uid(),    dataNew());
      allow list:   alertCanList(uid(),   dataNew());
      allow create: alertCanCreate(uid(), dataNew());
      allow update: alertCanUpdate(uid(), dataOld(), dataNew());
      allow delete: alertCanDelete(uid(), dataNew());
    }

    match /clusters/{clusterId} {
      allow get:    clusterCanGet(uid(),    dataNew());
      allow list:   clusterCanList(uid(),   dataNew());
      allow create: clusterCanCreate(uid(), dataNew());
      allow update: clusterCanUpdate(uid(), dataOld(), dataNew());
      allow delete: clusterCanDelete(uid(), dataNew());
    }

    match /cities/{cityId} {
      allow get:    cityCanGet(uid(),    dataNew());
      allow list:   cityCanList(uid(),   dataNew());
      allow create: cityCanCreate(uid(), dataNew());
      allow update: cityCanUpdate(uid(), dataOld(), dataNew());
      allow delete: cityCanDelete(uid(), dataNew());
    }

    match /events/{eventId} {
      allow get:    eventCanGet(uid(),    dataNew());
      allow list:   eventCanList(uid(),   dataNew());
      allow create: eventCanCreate(uid(), dataNew());
      allow update: eventCanUpdate(uid(), dataOld(), dataNew());
      allow delete: eventCanDelete(uid(), dataNew());
    }

    match /icons/{iconId} {
      allow get:    iconCanGet(uid(),    dataNew());
      allow list:   iconCanList(uid(),   dataNew());
      allow create: iconCanCreate(uid(), dataNew());
      allow update: iconCanUpdate(uid(), dataOld(), dataNew());
      allow delete: iconCanDelete(uid(), dataNew());
    }

    match /images/{imageId} {
      allow get:    imageCanGet(uid(),    dataNew());
      allow list:   imageCanList(uid(),   dataNew());
      allow create: imageCanCreate(uid(), dataNew());
      allow update: imageCanUpdate(uid(), dataOld(), dataNew());
      allow delete: imageCanDelete(uid(), dataNew());
    }

    match /streams/{cityId} {
      allow get:    streamCanGet(uid(),    dataNew());
      allow list:   streamCanList(uid(),   dataNew());
      allow create: streamCanCreate(uid(), dataNew());
      allow update: streamCanUpdate(uid(), dataOld(), dataNew());
      allow delete: streamCanDelete(uid(), dataNew());
    }

    match /users/{userId} {
      allow get:    userCanGet(uid(),    dataNew());
      allow list:   userCanList(uid(),   dataNew());
      allow create: userCanCreate(uid(), dataNew());
      allow update: userCanUpdate(uid(), dataOld(), dataNew());
      allow delete: userCanDelete(uid(), dataNew());
    }

    match /user-profiles/{userId} {
      allow get:    userProfileCanGet(uid(),    dataNew());
      allow list:   userProfileCanList(uid(),   dataNew());
      allow create: userProfileCanCreate(uid(), dataNew());
      allow update: userProfileCanUpdate(uid(), dataOld(), dataNew());
      allow delete: userCanDelete(uid(), dataNew());
    }

    function documentValidCreate(uid, data)
    {
        return data.version     == null &&
               data.id          == null &&
               data.userId      == uid  &&
               data.dateCreated == null &&
               data.dateUpdated == null &&
               data.metadata    == null;
    }

    function documentValidUpdate(uid, dataOld, dataNew)
    {
        return dataNew.version     == dataOld.version     &&
               dataNew.id          == dataOld.id          &&
               dataNew.userId      == dateOld.userId      &&
               dataNew.dateCreated == dataOld.dateCreated &&
               dataNew.dateUpdated is timestamp           &&
               dataNew.metadata    == null;
    }

    function alertValidCreate(uid, data)
    {
        return false;
    }

    function alertValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew) &&
               dataNew.name        == dataOld.name        &&
               dataNew.description == dataOld.description &&
               dataNew.bucketPath  == dataOld.bucketPath  &&
               dataNew.eventId     == dataOld.eventId     &&
               dataNew.clusterId   == dataOld.clusterId   &&
               dataNew.dateTime    == dataOld.dateTime    &&
               dataNew.tokens      == dataOld.tokens      &&
               dataNew.url         == dataOld.url         &&
               !dataOld.read                              &&
               dataNew.read;
    }

    function cityValidCreate(uid, data)
    {
        return false;
    }

    function cityValidUpdate(uid, dataOld, dataNew)
    {
        return false;
    }

    function clusterValidCreate(uid, data)
    {
        return documentValidCreate(uid, data) &&
               data.name            is string &&
               data.tagline         is string &&
               data.description     is string &&
               data.bucketPath      is string &&
               data.private         is bool   &&
               data.subscriberCount == 0;
    }

    function clusterValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew) &&
               dataNew.name            is string          &&
               dataNew.tagline         is string          &&
               dataNew.description     is string          &&
               dataNew.bucketPath      is string          &&
               dataNew.private         is bool            &&
               dataNew.subscriberCount == dataOld.subscriberCount;
    }

    function eventValidCreate(uid, data)
    {
        return documentValidCreate(uid, data) &&
               data.name            is string &&
               data.tagline         is string &&
               data.description     is string &&
               data.bucketPath      is string &&
               data.private         is bool   &&
               data.geopoint        is latlng &&
               data.city            != null   &&
               data.city.latlng     is latlng &&
               data.city.cityId     is string &&
               data.city.city       is string &&
               data.city.region     is string &&
               data.city.country    is string &&
               data.timeStart       is string &&
               data.timeEnd         is string &&
               data.timeNotify      is string &&
               data.clusters        is array  &&
               data.clusters.size() == 1      &&
               !data.notifyComplete;
    }

    function eventValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew)         &&
               dataNew.name            is string                  &&
               dataNew.tagline         is string                  &&
               dataNew.description     is string                  &&
               dataNew.bucketPath      is string                  &&
               dataNew.private         is bool                    &&
               dataNew.latlng          is latlng                  &&
               dataNew.city            != null                    &&
               dataNew.city.latlng     is latlng                  &&
               dataNew.city.cityId     is string                  &&
               dataNew.city.city       is string                  &&
               dataNew.city.region     is string                  &&
               dataNew.city.country    is string                  &&
               dataNew.timeStart       is string                  &&
               dataNew.timeEnd         is string                  &&
               dataNew.timeNotify      is string                  &&
               dataNew.clusters        is array                   &&
               dataNew.clusters.size() == dataOld.clusters.size() &&
               !data.notifyComplete;
    }

    function iconValidCreate(uid, data)
    {
        return documentValidCreate(uid, data) &&
               data.name        is string     &&
               data.description is string     &&
               data.bucketPath  is string     &&
               data.mediaType   is string;
    }

    function iconValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew) &&
               dataNew.name        is string              &&
               dataNew.description is string              &&
               dataNew.bucketPath  is string              &&
               dataNew.mediaType   is string;
    }

    function imageValidCreate(uid, data)
    {
        return documentValidCreate(uid, data) &&
               data.name        is string     &&
               data.description is string     &&
               data.bucketPath  is string     &&
               data.mediaType   is string;
    }

    function imageValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew) &&
               dataNew.name        is string              &&
               dataNew.description is string              &&
               dataNew.bucketPath  is string              &&
               dataNew.mediaType   is string;
    }

    function streamValidCreate(uid, data)
    {
        return false;
    }

    function imageValidUpdate(uid, dataOld, dataNew)
    {
        return false;
    }

    function userValidCreate(uid, data)
    {
        return documentValidCreate(uid, data)      &&
               data.providerId          == 'email' &&
               data.language            is string  &&
               data.email               is string  &&
               data.phoneNumber         is string  &&
               data.geopoint            is latlng  &&
               data.city                != null    &&
               data.city.latlng         is latlng  &&
               data.city.cityId         is string  &&
               data.city.city           is string  &&
               data.city.region         is string  &&
               data.city.country        is string  &&
               data.tokens              is array   &&
               data.subscriptions       is array   &&
               data.subscriptionsStatus != null    &&
               data.roleEditors         is array   &&
               data.roleEditors.size()  == 0       &&
               data.roleAdmins          is array   &&
               data.roleAdmins.size()   == 0;
    }

    function userValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew) &&
               dataNew.providerId          == 'password'  &&
               dataNew.language            is string      &&
               dataNew.email               is string      &&
               dataNew.phoneNumber         is string      &&
               dataNew.geopoint            is latlng      &&
               dataNew.city                != null        &&
               dataNew.city.latlng         is latlng      &&
               dataNew.city.cityId         is string      &&
               dataNew.city.city           is string      &&
               dataNew.city.region         is string      &&
               dataNew.city.country        is string      &&
               dataNew.tokens              is array       &&
               dataNew.subscriptions       is array       &&
               dataNew.subscriptionsStatus is map         &&
               dataNew.roleEditors         is array       &&
               dataNew.roleAdmins          is array;
    }

    function userProfileValidCreate(uid, data)
    {
        return documentValidCreate(uid, data) &&
               data.nameFirst   is string         &&
               data.nameLast    is string         &&
               data.bucketPath  is string         &&
               data.companyName is string         &&
               data.isCompany   is bool;
    }

    function userProfileValidUpdate(uid, dataOld, dataNew)
    {
        return documentValidUpdate(uid, dataOld, dataNew) &&
               dataNew.nameFirst   is string              &&
               dataNew.nameLast    is string              &&
               dataNew.bucketPath  is string              &&
               dataNew.companyName is string              &&
               dataNew.isCompany   is bool;
    }

    function auth()                             { return request.auth; }
    function uid()                              { return auth().uid; }
    function isAuthenticated(uid)               { return uid != null; }
    function dataOld()                          { return resource.data; }
    function dataNew()                          { return request.resource.data; }
    function document(collection, id)           { return get(/databases/${database}/documents/$(collection)/$(id)); }
    function user(data)                         { return document('users', data.userId); }
    function isDataOwner(uid, data)             { return uid == data.userId; }
    function isSuperAdmin(uid)                  { return uid == 'baLysAd71cRyZjh0hr6poxR8an13'; }
    function hasRoleEditor(uid, data, user)     { return isDataOwner(uid, data) || isSuperAdmin(uid) || user.roleAdmins[uid] != null || user.roleEditors[uid] != null; }
    function hasRoleAdmin(uid, data)            { return isDataOwner(uid, data) || isSuperAdmin(uid) || user(data).roleAdmins[uid] != null; }
    function isPublic(data)                     { return data.private != null || !data.private; }

    function itemCanGet(uid, data)    { return isDataOwner(uid, data) || isSuperAdmin(uid); }
    function itemCanList(uid, data)   { return isDataOwner(uid, data) || isSuperAdmin(uid); }
    function itemCanCreate(uid, data) { return isDataOwner(uid, data) || isSuperAdmin(uid); }
    function itemCanUpdate(uid, data) { return isDataOwner(uid, data) || isSuperAdmin(uid); }
    function itemCanDelete(uid, data) { return isDataOwner(uid, data) || isSuperAdmin(uid); }

    function assetCanGet(uid, data)    { return isPublic(data) || hasRoleEditor(uid, data, user(data)); }
    function assetCanList(uid, data)   { return isPublic(data) || hasRoleEditor(uid, data, user(data)); }
    function assetCanCreate(uid, data) { return hasRoleAdmin(uid, data); }
    function assetCanUpdate(uid, data) { return hasRoleEditor(uid, data, user(data)); }
    function assetCanDelete(uid, data) { return hasRoleAdmin(uid, data); }

    function alertCanGet(uid, data)                { return itemCanGet(uid, data); }
    function alertCanList(uid, data)               { return itemCanList(uid, data); }
    function alertCanCreate(uid, data)             { return false; }
    function alertCanUpdate(uid, dataOld, dataNew) { return alertValidUpdate(uid, dataOld, dataNew) && itemCanUpdate(uid, dataOld); }
    function alertCanDelete(uid, data)             { return itemCanDelete(uid, data); }

    function cityCanGet(uid, data)                { return false; }
    function cityCanList(uid, data)               { return false; }
    function cityCanCreate(uid, data)             { return false; }
    function cityCanUpdate(uid, dataOld, dataNew) { return false; }
    function cityCanDelete(uid, data)             { return false; }

    function clusterCanGet(uid, data)                { return assetCanGet(uid, data); }
    function clusterCanList(uid, data)               { return assetCanList(uid, data); }
    function clusterCanCreate(uid, data)             { return clusterValidCreate(uid, data) && assetCanCreate(uid, data); }
    function clusterCanUpdate(uid, dataOld, dataNew) { return clusterValidUpdate(uid, dataOld, dataNew) && assetCanUpdate(uid, dataOld); }
    function clusterCanDelete(uid, data)             { return assetCanDelete(uid, data); }

    function eventCanGet(uid, data)                { return assetCanGet(uid, data); }
    function eventCanList(uid, data)               { return assetCanList(uid, data); }
    function eventCanCreate(uid, data)             { return eventValidCreate(uid, data) && assetCanCreate(uid, data); }
    function eventCanUpdate(uid, dataOld, dataNew) { return eventValidUpdate(uid, dataOld, dataNew) && assetCanUpdate(uid, dataOld); }
    function eventCanDelete(uid, data)             { return assetCanDelete(uid, data); }

    function iconCanGet(uid, data)                { return assetCanGet(uid, data); }
    function iconCanList(uid, data)               { return assetCanList(uid, data); }
    function iconCanCreate(uid, data)             { return iconValidCreate(uid, data) && assetCanCreate(uid, data); }
    function iconCanUpdate(uid, dataOld, dataNew) { return iconValidUpdate(uid, dataOld, dataNew) && assetCanUpdate(uid, dataOld); }
    function iconCanDelete(uid, data)             { return assetCanDelete(uid, data); }

    function imageCanGet(uid, data)                { return assetCanGet(uid, data); }
    function imageCanList(uid, data)               { return assetCanList(uid, data); }
    function imageCanCreate(uid, data)             { return imageValidCreate(uid, data) && assetCanCreate(uid, data); }
    function imageCanUpdate(uid, dataOld, dataNew) { return imageValidUpdate(uid, dataOld, dataNew) && assetCanUpdate(uid, dataOld); }
    function imageCanDelete(uid, data)             { return assetCanDelete(uid, data); }

    function streamCanGet(uid, data)                { return user(data).city.cityId == data.id; }
    function streamCanList(uid, data)               { return false; }
    function streamCanCreate(uid, data)             { return false; }
    function streamCanUpdate(uid, dataOld, dataNew) { return false; }
    function streamCanDelete(uid, data)             { return false; }

    function userCanGet(uid, data)                { return assetCanGet(uid, data); }
    function userCanList(uid, data)               { return false; }
    function userCanCreate(uid, data)             { return userValidCreate(uid, data) && (isDataOwner(uid, data) || isSuperAdmin(uid)); }
    function userCanUpdate(uid, dataOld, dataNew) { return userValidUpdate(uid, dataOld, dataNew) && (isDataOwner(uid, data) || isSuperAdmin(uid)); }
    function userCanDelete(uid, data)             { return false; }

    function userRolesCanGet(uid, data)                { return hasRoleAdmin(uid, data); }
    function userRolesCanList(uid, data)               { return false; }
    function userRolesCanCreate(uid, data)             { return hasRoleAdmin(uid, data); }
    function userRolesCanUpdate(uid, dataOld, dataNew) { return hasRoleAdmin(uid, data); }
    function userRolesCanDelete(uid, data)             { return false; }

    function userProfileCanGet(uid, data)                { return isAuthenticated(uid); }
    function userProfileCanList(uid, data)               { return false; }
    function userProfileCanCreate(uid, data)             { return userProfileValidCreate(uid, data) && assetCanCreate(uid, data); }
    function userProfileCanUpdate(uid, dataOld, dataNew) { return userProfileValidUpdate(uid, dataOld, dataNew) && assetCanUpdate(uid, dataOld); }
    function userProfileCanDelete(uid, data)             { return false; }
}
