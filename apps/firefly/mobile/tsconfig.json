{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "esnext",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "lib": ["es2018", "dom"],
    "typeRoots": ["node_modules/@types"],
    "paths": {
      "@firefly/app/env": ["./src/environments/environment.ts"],
      "@firefly/app/*": ["./src/app/*"],
      "@firefly/page": ["./src/app/pages"],
      "@firefly/page/*": ["./src/app/pages/*"],
      "@firefly/cloud": ["../cloud/src/library/index.ts"]
    }
  },
  "files": [],
  "include": [],
  "references": [
    {
      "path": "./src/tsconfig.app.json"
    },
    {
      "path": "./src/tsconfig.spec.json"
    }
  ]
}
