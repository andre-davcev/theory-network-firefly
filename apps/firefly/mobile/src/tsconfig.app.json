{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/app",
    "module": "es2015",
    "baseUrl": "./",
    "paths": {
      "@theory/scss": [
        "../../../../libs/scss"
      ],
      "@theory/capacitor": [
        "../../../../libs/capacitor/index.ts"
      ],
      "@theory/capacitor/*": [
        "../../../../libs/capacitor/src/*"
      ],
      "@theory/core": [
        "../../../../libs/core/index.ts"
      ],
      "@theory/core/*": [
        "../../../../libs/core/src/*"
      ],
      "@theory/core/feature/*": [
        "../../../../libs/core/src/features/*"
      ],
      "@theory/firebase": [
        "../../../../libs/firebase/index.ts"
      ],
      "@theory/firebase/*": [
        "../../../../libs/firebase/src/*"
      ],
      "@theory/foursquare": [
        "../../../../libs/foursquare/index.ts"
      ],
      "@theory/foursquare/*": [
        "../../../../libs/foursquare/src/*"
      ],
      "@theory/google": [
        "../../../../libs/google/index.ts"
      ],
      "@theory/google/*": [
        "../../../../libs/google/src/*"
      ],
      "@theory/ionic": [
        "../../../../libs/ionic/index.ts"
      ],
      "@theory/ionic/*": [
        "../../../../libs/ionic/src/*"
      ],
      "@theory/mapbox": [
        "../../../../libs/mapbox/index.ts"
      ],
      "@theory/mapbox/*": [
        "../../../../libs/mapbox/src/*"
      ],
      "@theory/nativescript": [
        "../../../../libs/nativescript/index.ts"
      ],
      "@theory/nativescript/*": [
        "../../../../libs/nativescript/src/*"
      ],
      "@theory/web": [
        "../../../../libs/web/index.ts"
      ],
      "@theory/web/*": [
        "../../../../libs/web/src/*"
      ],
      "@firefly/core": [
        "../../../../libs/firefly/core/index.ts"
      ],
      "@firefly/core/*": [
        "../../../../libs/firefly/core/src/*"
      ],
      "@firefly/core/component/*": [
        "../../../../libs/firefly/core/src/components/*"
      ],
      "@firefly/core/state/*": [
        "../../../../libs/firefly/core/src/state/*"
      ],
      "@firefly/mobile": [
        "../../../../libs/firefly/mobile/index.ts"
      ],
      "@firefly/mobile/*": [
        "../../../../libs/firefly/mobile/src/*"
      ],
      "@firefly/mobile/component/*": [
        "../../../../libs/firefly/mobile/src/components/*"
      ],
      "@firefly/mobile/state/*": [
        "../../../../libs/firefly/mobile/src/state/*"
      ],
      "@firefly/app/env": [
        "./environments/environment.ts"
      ],
      "@firefly/app/*": [
        "./app/*"
      ],
      "@firefly/page": [
        "./app/pages"
      ],
      "@firefly/page/*": [
        "./app/pages/*"
      ]
    }
  },
  "exclude": [
    "test.ts",
    "**/*.spec.ts"
  ]
}
