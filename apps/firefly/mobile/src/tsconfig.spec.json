{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/spec",
    "module": "commonjs",
    "types": [
      "jasmine",
      "node"
    ],
    "baseUrl": "./",
    "paths": {
      "@theory/scss": [
        "../../../../libs/scss"
      ],
      "@theory/capacitor": [
        "../../../../libs/capacitor/index.ts"
      ],
      "@theory/capacitor/*": [
        "../../../../libs/capacitor/src/*"
      ],
      "@theory/cordova": [
        "../../../../libs/cordova/index.ts"
      ],
      "@theory/cordova/*": [
        "../../../../libs/cordova/src/*"
      ],
      "@theory/core": [
        "../../../../libs/core/index.ts"
      ],
      "@theory/core/*": [
        "../../../../libs/core/src/*"
      ],
      "@theory/core/feature/*": [
        "../../../../libs/core/src/features/*"
      ],
      "@theory/firebase": [
        "../../../../libs/firebase/index.ts"
      ],
      "@theory/firebase/*": [
        "../../../../libs/firebase/src/*"
      ],
      "@theory/google": [
        "../../../../libs/google/index.ts"
      ],
      "@theory/google/*": [
        "../../../../libs/google/src/*"
      ],
      "@theory/ionic": [
        "../../../../libs/ionic/index.ts"
      ],
      "@theory/ionic/*": [
        "../../../../libs/ionic/src/*"
      ],
      "@theory/mapbox": [
        "../../../../libs/mapbox/index.ts"
      ],
      "@theory/mapbox/*": [
        "../../../../libs/mapbox/src/*"
      ],
      "@theory/nativescript": [
        "../../../../libs/nativescript/index.ts"
      ],
      "@theory/nativescript/*": [
        "../../../../libs/nativescript/src/*"
      ],
      "@theory/state": [
        "../../../../libs/state/index.ts"
      ],
      "@theory/state/*": [
        "../../../../libs/state/src/*"
      ],
      "@theory/web": [
        "../../../../libs/web/index.ts"
      ],
      "@theory/web/*": [
        "../../../../libs/web/src/*"
      ],
      "@firefly/core": [
        "../../../../libs/firefly/core/index.ts"
      ],
      "@firefly/core/*": [
        "../../../../libs/firefly/core/src/*"
      ],
      "@firefly/mobile": [
        "../../../../libs/firefly/mobile/index.ts"
      ],
      "@firefly/mobile/*": [
        "../../../../libs/firefly/mobile/src/*"
      ],
      "@firefly/app/env": [
        "./environments/environment.ts"
      ],
      "@firefly/app/*": [
        "./app/*"
      ],
      "@firefly/page": [
        "./app/pages"
      ],
      "@firefly/page/*": [
        "./app/pages/*"
      ]
    }
  },
  "files": [
    "test.ts"
  ],
  "include": [
    "polyfills.ts",
    "**/*.spec.ts",
    "**/*.d.ts"
  ]
}
