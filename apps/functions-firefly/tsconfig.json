{
  "compilerOptions": {
    "lib": ["es6"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "outDir": "lib",
    "sourceMap": true,
    "target": "es6",
    "declaration": true,
    "inlineSources": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "baseUrl": ".",
    "paths": {
      "@theory/scss": [
        "../../libs/scss"
      ],
      "@theory/capacitor": [
        "../../libs/capacitor/index.ts"
      ],
      "@theory/capacitor/*": [
        "../../libs/capacitor/src/*"
      ],
      "@theory/core": [
        "../../libs/core/index.ts"
      ],
      "@theory/core/*": [
        "../../libs/core/src/*"
      ],
      "@theory/core/feature/*": [
        "../../libs/core/src/features/*"
      ],
      "@theory/device": [
        "../../libs/device/index.ts"
      ],
      "@theory/device/*": [
        "../../libs/device/src/*"
      ],
      "@theory/firebase": [
        "../../libs/firebase/index.ts"
      ],
      "@theory/firebase/*": [
        "../../libs/firebase/src/*"
      ],
      "@theory/foursquare": [
        "../../libs/foursquare/index.ts"
      ],
      "@theory/foursquare/*": [
        "../../libs/foursquare/src/*"
      ],
      "@theory/google": [
        "../../libs/google/index.ts"
      ],
      "@theory/google/*": [
        "../../libs/google/src/*"
      ],
      "@theory/ionic": [
        "../../libs/ionic/index.ts"
      ],
      "@theory/ionic/*": [
        "../../libs/ionic/src/*"
      ],
      "@theory/mapbox": [
        "../../libs/mapbox/index.ts"
      ],
      "@theory/mapbox/*": [
        "../../libs/mapbox/src/*"
      ],
      "@theory/nativescript": [
        "../../libs/nativescript/index.ts"
      ],
      "@theory/nativescript/*": [
        "../../libs/nativescript/src/*"
      ],
      "@theory/web": [
        "../../libs/web/index.ts"
      ],
      "@theory/web/*": [
        "../../libs/web/src/*"
      ],
      "@firefly/core": [
        "../../libs/firefly/core/index.ts"
      ],
      "@firefly/core/*": [
        "../../libs/firefly/core/src/*"
      ],
      "@firefly/core/component/*": [
        "../../libs/firefly/core/src/components/*"
      ],
      "@firefly/core/state/*": [
        "../../libs/firefly/core/src/state/*"
      ],
      "@firefly/mobile": [
        "../../libs/firefly/mobile/index.ts"
      ],
      "@firefly/mobile/*": [
        "../../libs/firefly/mobile/src/*"
      ],
      "@firefly/mobile/component/*": [
        "../../libs/firefly/mobile/src/components/*"
      ],
      "@firefly/mobile/state/*": [
        "../../libs/firefly/mobile/src/state/*"
      ],
      "@firefly/app/env": [
        "apps/ionic-firefly/src/environments/environment.ts"
      ],
      "@firefly/app/*": [
        "apps/ionic-firefly/src/app/*"
      ],
      "@firefly/app/page/*": [
        "apps/ionic-firefly/src/app/pages/*"
      ],
      "@firefly/functions": [
        "../../libs/firefly/functions/index.ts"
      ],
      "@firefly/functions/*": [
        "../../libs/firefly/functions/src/*"
      ]
    }
  },
  "compileOnSave": true,
  "include": [
    "src"
  ],
  "files": [
    "node_modules/typescript/lib/lib.es6.d.ts"
  ],
  "exclude": [
    "node_modules",
    "src/test.ts",
    "**/*.spec.ts"
  ]
}
