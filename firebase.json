{
  "hosting": [{
    "target": "firefly-web",
    "site": "firefly-web",
    "public": "dist/apps/firefly-web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }]
}
